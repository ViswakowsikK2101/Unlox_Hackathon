# =============================================================================
# CampusFlow Backend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in every value before starting the server.
# The backend will REFUSE to start if any required variable is missing.
# See environment.md for a full description of every variable.
# =============================================================================


# -----------------------------------------------------------------------------
# SERVER
# -----------------------------------------------------------------------------

# The port the Express server will listen on.
# Render sets this automatically in production; set it manually for local dev.
PORT=3000

# Runtime environment. Controls logging format, error verbosity, and behaviour.
# Accepted values: development | production | test
NODE_ENV=development


# -----------------------------------------------------------------------------
# SUPABASE
# -----------------------------------------------------------------------------

# The full URL of your Supabase project.
# Found in: Supabase Dashboard → Settings → API → Project URL
# Example:  https://xyzxyzxyz.supabase.co
SUPABASE_URL=https://your-project-id.supabase.co

# The anon/public key for your Supabase project.
# This is also the token the frontend sends as: Authorization: Bearer <key>
# Found in: Supabase Dashboard → Settings → API → anon public
SUPABASE_ANON_KEY=your-supabase-anon-key

# The service_role key. Grants admin-level access — bypasses Row Level Security.
# Used ONLY for internal backend operations that require elevated privileges.
# NEVER expose this key to the frontend.
# Found in: Supabase Dashboard → Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key


# -----------------------------------------------------------------------------
# n8n WEBHOOKS
# (Provided by the n8n teammate once their workflows are deployed.)
# -----------------------------------------------------------------------------

# The n8n webhook URL that triggers the deadline reminder workflow.
# Backend POSTs the deadline payload to this URL when a reminder is requested.
# Example: https://your-n8n-instance.com/webhook/deadline-reminder
N8N_DEADLINE_WEBHOOK=https://your-n8n-instance.com/webhook/deadline-reminder

# The n8n webhook URL that triggers the notice broadcast workflow.
# Backend POSTs the notice payload to this URL when a notice is published.
# Example: https://your-n8n-instance.com/webhook/notice-broadcast
N8N_NOTICE_WEBHOOK=https://your-n8n-instance.com/webhook/notice-broadcast


# -----------------------------------------------------------------------------
# PYTHON AI SERVICE
# (Provided by the Python AI teammate once their service is deployed.)
# -----------------------------------------------------------------------------

# The base URL of the Python AI FastAPI service.
# Backend forwards AI queries to: <PYTHON_AI_BASE_URL>/query
# Example: https://campusflow-ai.onrender.com
PYTHON_AI_BASE_URL=http://localhost:8000


# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------

# Comma-separated list of allowed frontend origins.
# No spaces between entries.
# Example (local + production): http://localhost:3001,https://campusflow.vercel.app
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000


# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------

# Duration of the rate limiting window, in milliseconds.
# Default: 900000 (15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Maximum number of requests per IP allowed within the window.
# Default: 100
RATE_LIMIT_MAX=100


# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------

# Pino log level.
# Accepted values: trace | debug | info | warn | error | fatal | silent
# Use 'debug' locally, 'info' in production.
LOG_LEVEL=debug
